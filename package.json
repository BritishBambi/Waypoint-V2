{
  "name": "waypoint",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "db:push": "npx supabase db push",
    "db:reset": "npx supabase db reset",
    "db:types": "npx supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > packages/types/src/database.ts",
    "functions:list": "npx supabase functions list",
    "functions:deploy": "npx supabase functions deploy",
    "secrets:set": "npx supabase secrets set",
    "supabase:start": "npx supabase start",
    "generate:types": "npx supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > packages/types/src/database.ts"
  },
  "devDependencies": {
    "supabase": "^2.76.15",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
